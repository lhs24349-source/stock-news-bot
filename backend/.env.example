# ============================================================
# 주식 뉴스 알림 봇 - 환경 변수 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요:
#   cp .env.example .env
# ============================================================

# ── 앱 기본 설정 ──────────────────────────────────────────────
APP_NAME=stock-news-bot
APP_ENV=development          # development | staging | production
DEBUG=true                   # true: 디버그 모드 (상세 로그)
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── 데이터베이스 (SQLite / PostgreSQL) ───────────────────────
# SQLite (개발용, 기본값)
DATABASE_URL=sqlite+aiosqlite:///./stock_news.db

# PostgreSQL (운영용, Docker 사용 시)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stock_news

# ── Redis (선택사항 - 미설정 시 SQLite 폴백) ────────────────
# REDIS_URL=redis://localhost:6379/0

# ── 알림 채널: Telegram ─────────────────────────────────────
# @BotFather에서 봇 생성 후 토큰 입력
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# 채팅 ID 확인: https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_CHAT_ID=123456789

# ── 알림 채널: Discord ──────────────────────────────────────
# 서버 설정 → 연동 → 웹훅 → 새 웹훅 → URL 복사
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ── 알림 채널: Gmail ────────────────────────────────────────
# 2FA 활성화 후 앱 비밀번호 발급 필요
# Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
# GMAIL_ADDRESS=your-email@gmail.com
# GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
# GMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# ── RSS 소스 설정 ────────────────────────────────────────────
NAVER_RSS_URL=https://finance.naver.com/rss/headline.naver?catId=101
GOOGLE_NEWS_RSS_URL=https://news.google.com/rss/search?q={keyword}+when:1d&hl=ko&gl=KR&ceid=KR:ko

# ── Alpha Vantage (선택사항) ─────────────────────────────────
# https://www.alphavantage.co/support/#api-key 에서 무료 키 발급
# ALPHA_VANTAGE_API_KEY=your_api_key_here

# ── 스케줄러 설정 ────────────────────────────────────────────
SCHEDULER_DEFAULT_INTERVAL_MINUTES=30   # 기본 뉴스 수집 간격 (분)
SCHEDULER_TIMEZONE=Asia/Seoul

# ── CORS (프론트엔드 URL) ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Sentry (선택사항, 에러 트래킹) ───────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy
